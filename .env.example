# Monolith API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:3333

# Server-only BFF upstream. May use a private network address in production.
BACKEND_API_URL=http://localhost:3333

# Default tenant — must match ts-monolith seed
NEXT_PUBLIC_DEFAULT_TENANT_ID=00000000-0000-4000-8000-000000000001

# direct (transparent localStorage demo) | bff (httpOnly cookie session)
# Defaults to direct in development and bff in production.
NEXT_PUBLIC_AUTH_MODE=direct

# Server-only comma-separated origins accepted for BFF state-changing requests.
BFF_ALLOWED_ORIGINS=http://localhost:3000

# Tooling only: local path or HTTP(S) URL used by `npm run api:sync`.
# Defaults to ../ts-monolith/openapi/openapi.json when the repos are siblings.
OPENAPI_SOURCE=../ts-monolith/openapi/openapi.json
